        height: 648,
    },
]

const testimonials = [
    {
        name: 'Sarah Johnson',
        role: 'Wedding Client',
        review: 'The arrangements were absolutely stunning! Every flower was fresh and beautiful. Thank you for making our special day perfect.',
        rating: 5,
    },
    {
        name: 'Michael Chen',
        role: 'Corporate Client',
        review: 'Professional service and gorgeous flowers. We send Bloom & Blossom arrangements to all our important clients. Highly recommended!',
        rating: 5,
