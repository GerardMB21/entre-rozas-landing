import { MapPin, Phone, Mail } from '@lucide/astro'

const phone = '977445864'
const email = 'contacto@entrerozas.pe'

const flowers = [
    {
        id: 1,
        name: 'Premium Rose Bouquet',
        image: '/flowers-rose-bouquet.webp',
        description: 'Luxurious red and pink roses',
        price: '$89.99',
        width: 1152,
        height: 648,
    },
    {
        id: 2,
        name: 'Sunny Sunflower Mix',
        image: '/flowers-sunflower.webp',
        description: 'Bright and cheerful arrangement',
        price: '$74.99',
        width: 1152,
        height: 648,
    },
    {
        id: 3,
        name: 'Spring Tulips',
        image: '/flowers-tulips.webp',
        description: 'Fresh seasonal tulips',
        price: '$69.99',
        width: 1152,
        height: 648,
    },
    {
        id: 4,
        name: 'Exotic Orchids',
        image: '/flowers-orchids.webp',
        description: 'Premium orchid collection',
        price: '$99.99',
        width: 1152,
        height: 648,
    },
]
const testimonials = [
    {
        name: 'Sarah Johnson',
        role: 'Wedding Client',
        review: 'The arrangements were absolutely stunning! Every flower was fresh and beautiful. Thank you for making our special day perfect.',
        rating: 5,
    },
    {
        name: 'Michael Chen',
        role: 'Corporate Client',
        review: 'Professional service and gorgeous flowers. We send Bloom & Blossom arrangements to all our important clients. Highly recommended!',
        rating: 5,
    },
    {
        name: 'Emma Rodriguez',
        role: 'Regular Customer',
        review: 'I love ordering from here. The quality is consistently excellent and they always deliver with a smile. Best florist in town!',
        rating: 5,
    },
]
const locationInfo = {
    address: 'Ramon Espinoza 10, Rímac 15001',
    addressLink: 'https://maps.app.goo.gl/ZvSGKjvAHodMKU1B7',
    phone: '977445864',
    email: 'contacto@entrerozas.pe',
    locationItems: [
        {
            icon: MapPin,
            name: 'Dirección',
            linkRef: 'https://maps.app.goo.gl/ZvSGKjvAHodMKU1B7',
            text: 'Ramon Espinoza 10, Rímac 15001',
        },
        {
            icon: Phone,
            name: 'Teléfono',
            linkRef: `tel:+51${phone}`,
            text: phone,
        },
        {
            icon: Mail,
            name: 'Email',
            linkRef: `mailto:${email}`,
            text: email,
        },
    ],
    timeSchedule: ['Lun - Vier: 8:00 am - 5:00 pm', 'Sab: 8:00 am - 1:00 pm'],
}
---

<Layout>
    <Carousel flowers={flowers} />
    <Featured flowers={flowers} />
    <Location locationInfo={locationInfo} />
    <Testimonials testimonials={testimonials} />
    <Shopping />
    <Contact />
</Layout>
