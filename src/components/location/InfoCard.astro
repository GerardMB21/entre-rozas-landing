---
import type { LocationInfo } from '@/interfaces/location'
import InfoItem from './InfoItem.astro'

interface Props {
    locationInfo: LocationInfo
}

const { locationInfo } = Astro.props
---

<div class="space-y-6">
    {
        locationInfo.locationItems.map(({ icon, name, linkRef, text }) => (
            <InfoItem icon={icon} name={name} linkRef={linkRef} text={text} />
        ))
    }
    <div class="mt-8 p-6 bg-card rounded-lg">
        <h3 class="font-medium mb-3 text-foreground">Horario</h3>
        <div class="space-y-2 text-sm text-foreground/70">
            {locationInfo.timeSchedule.map((i) => <p>{i}</p>)}
        </div>
    </div>
</div>
