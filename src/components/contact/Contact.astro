<section
    id="contact"
    class="py-12 sm:py-16 px-3 sm:px-4 bg-primary text-primary-foreground"
>
    <div class="max-w-6xl mx-auto text-center">
        <h2 class="h1-xl mb-4 sm:mb-6 text-2xl sm:text-4xl">Contáctenos</h2>
        <p
            class="body-lg mb-6 sm:mb-8 max-w-2xl mx-auto opacity-90 text-sm sm:text-base"
        >
            Tienes dudas? Deseas un arreglo personalizado? te escuchamos!
        </p>
        <div class="flex gap-3 sm:gap-4 justify-center flex-wrap">
            <button
                class="bg-primary-foreground text-primary cursor-pointer px-6 sm:px-8 py-2 sm:py-3 rounded-lg hover:opacity-90 transition font-medium text-sm sm:text-base"
            >
                Escríbenos
            </button>
            <button
                class="border-2 border-primary-foreground cursor-pointer px-6 sm:px-8 py-2 sm:py-3 rounded-lg hover:bg-primary-foreground/10 transition font-medium text-sm sm:text-base"
            >
                Llámanos
            </button>
        </div>
    </div>
</section>
