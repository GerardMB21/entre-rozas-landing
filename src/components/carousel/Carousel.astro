---
import type { Flower } from '@interfaces/carousel'
import { ChevronLeft, ChevronRight } from '@lucide/astro'
import Card from './Card.astro'
import Dot from './Dot.astro'

export interface Props {
    flowers: Flower[]
}

const { flowers } = Astro.props
---

<section class="mt-24 px-4 py-12">
    <div class="max-w-6xl mx-auto">
        <div
            data-carousel
            class="relative w-full aspect-video overflow-hidden rounded-2xl bg-card shadow-lg"
        >
            <div class="relative w-full h-full">
                {
                    flowers.map((flower, index) => (
                        <Card index={index} flower={flower} />
                    ))
                }
            </div>
            <button
                data-carousel-prev
                class="btn-carousel left-4"
                aria-label="Previous slide"
            >
                <ChevronLeft size={24} />
            </button>
            <button
                data-carousel-next
                class="btn-carousel right-4"
                aria-label="Next slide"
            >
                <ChevronRight size={24} />
            </button>
            <div
                class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10"
            >
                {flowers.map((_, index) => <Dot index={index} />)}
            </div>
        </div>
    </div>
</section>

<script>
    function setupCarousel(root: HTMLElement) {
        const slides = Array.from(
            root.querySelectorAll<HTMLElement>('[data-carousel-slide]'),
        )
        const dots = Array.from(
            root.querySelectorAll<HTMLElement>('[data-carousel-dot]'),
        )
        const prevBtn = root.querySelector<HTMLElement>('[data-carousel-prev]')
        const nextBtn = root.querySelector<HTMLElement>('[data-carousel-next]')

        if (slides.length === 0) return

        let current = 0

        function goTo(index: number) {
            current = (index + slides.length) % slides.length

            slides.forEach((slide, i) => {
                const active = i === current
                slide.classList.toggle('opacity-100', active)
                slide.classList.toggle('opacity-0', !active)
            })

            dots.forEach((dot, i) => {
                const active = i === current
                dot.classList.toggle('btn-dot-expand', active)
                dot.classList.toggle('btn-dot-default', !active)
            })
        }

        prevBtn?.addEventListener('click', () => goTo(current - 1))
        nextBtn?.addEventListener('click', () => goTo(current + 1))

        dots.forEach((dot, i) => {
            dot.addEventListener('click', () => goTo(i))
        })

        let autoplay: ReturnType<typeof setInterval> | null = null

        function startAutoplay() {
            if (autoplay) return
            autoplay = setInterval(() => goTo(current + 1), 3000)
        }

        function stopAutoplay() {
            if (!autoplay) return
            clearInterval(autoplay)
            autoplay = null
        }

        root.addEventListener('mouseenter', stopAutoplay)
        root.addEventListener('mouseleave', startAutoplay)

        goTo(0)
        startAutoplay()
    }

    // eslint-disable-next-line @typescript-eslint/no-unused-expressions
    document
        .querySelectorAll<HTMLElement>('[data-carousel]')
        .forEach(setupCarousel)
</script>
