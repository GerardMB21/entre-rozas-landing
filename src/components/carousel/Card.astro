---
import type { Flower } from '@/interfaces/carousel'
import { Image } from 'astro:assets'

export interface Props {
    index: number
    flower: Flower
}

const { index, flower } = Astro.props
---

<div
    data-carousel-slide={index}
    class="absolute flex items-center justify-center inset-0 transition-opacity duration-500"
>
    <Image
        src={flower.image}
        alt={flower.name}
        class="object-cover object-center"
        width={flower.width}
        height={flower.height}
    />
    <div class="absolute inset-0 bg-linear-to-t from-black/40 to-transparent">
    </div>
    <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
        <h2 class="h1-xl mb-2">{flower.name}</h2>
        <p class="body-lg text-gray-100">
            {flower.description}
        </p>
    </div>
</div>
