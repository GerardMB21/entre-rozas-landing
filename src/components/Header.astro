---
import { Sun, Moon, Menu, X, ShoppingCart } from '@lucide/astro'

interface Props {
    whatsappPhone: string
}

const { whatsappPhone } = Astro.props
---

<header
    class="fixed top-0 w-full z-50 bg-background/95 backdrop-blur border-b border-border"
>
    <div
        class="max-w-7xl mx-auto p-3 sm:p-4 flex items-center justify-between gap-2 sm:gap-4"
    >
        <div class="relative shrink-0">
            <button
                id="menu-toggle"
                class="cursor-pointer p-2 rounded-lg hover:bg-muted transition text-foreground sm:hidden"
                aria-label="Abrir menú"
                aria-expanded="false"
                aria-controls="nav-menu"
            >
                <Menu size={24} class="block" data-menu-icon="open" />
                <X size={24} class="hidden" data-menu-icon="close" />
            </button>

            <nav class="hidden sm:flex gap-2 sm:gap-6 text-xs sm:text-base">
                <a href="#shop" class="link-nav"> Comprar </a>
                <a href="#contact" class="link-nav"> Contacto </a>
            </nav>
        </div>
        <div class="text-center flex-1 min-w-0">
            <h1
                class="text-xl font-light tracking-wide text-primary sm:text-3xl"
            >
                <span class="text-2xl sm:text-4xl">🌸</span> Entre Rozas
            </h1>
            <p class="caption text-xs text-muted-foreground">
                Arreglos Florales de Primera Calidad
            </p>
        </div>
        <div class="flex items-center gap-1 shrink-0 sm:gap-2">
            <button
                id="cart-toggle"
                class="relative cursor-pointer p-2 rounded-lg hover:bg-muted transition text-foreground"
                aria-label="Ver carrito"
                aria-expanded="false"
                aria-controls="cart-panel"
            >
                <ShoppingCart size={24} class="btn-theme block" />
                <span
                    id="cart-count"
                    class="absolute -top-0.5 -right-0.5 min-w-5 h-5 px-1 flex items-center justify-center rounded-full bg-primary text-primary-foreground text-xs font-medium"
                >
                    0
                </span>
            </button>
            <button
                id="theme-toggle"
                class="cursor-pointer p-2 rounded-lg hover:bg-muted transition text-foreground"
                aria-label="Cambiar tema"
            >
                <Sun size={24} class="btn-theme block dark:hidden" />
                <Moon size={24} class="btn-theme hidden dark:block" />
            </button>
        </div>
    </div>
</header>

<div
    id="drawer-overlay"
    class="hidden fixed inset-0 bg-black/50 z-40 transition-opacity"
>
</div>

<aside
    id="nav-menu"
    class="fixed top-0 left-0 z-50 flex h-full w-72 max-w-[80%] -translate-x-full flex-col bg-card border-r border-border shadow-lg transition-transform duration-300 sm:hidden"
>
    <div class="flex items-center justify-between p-4 border-b border-border">
        <span class="card-title">Menú</span>
        <button
            id="nav-menu-close"
            class="cursor-pointer p-2 rounded-lg hover:bg-muted transition text-foreground"
            aria-label="Cerrar menú"
        >
            <X size={20} />
        </button>
    </div>
    <nav class="flex flex-col gap-1 p-4">
        <a href="#shop" class="link-nav rounded px-3 py-2 hover:bg-muted">
            Comprar
        </a>
        <a href="#contact" class="link-nav rounded px-3 py-2 hover:bg-muted">
            Contacto
        </a>
    </nav>
</aside>

<aside
    id="cart-panel"
    class="fixed top-0 right-0 z-50 flex h-full w-80 max-w-[85%] translate-x-full flex-col bg-card border-l border-border shadow-lg transition-transform duration-300"
>
    <div class="flex items-center justify-between p-4 border-b border-border">
        <span class="card-title">Carrito</span>
        <button
            id="cart-panel-close"
            class="cursor-pointer p-2 rounded-lg hover:bg-muted transition text-foreground"
            aria-label="Cerrar carrito"
        >
            <X size={20} />
        </button>
    </div>
    <p id="cart-empty" class="flex-1 p-4 body-sm text-muted-foreground">
        Tu carrito está vacío.
    </p>
    <div
        id="cart-items"
        class="hidden flex-1 flex-col gap-4 overflow-y-auto p-4"
    >
    </div>
    <div id="cart-footer" class="hidden border-t border-border p-4">
        <div class="flex items-center justify-between mb-3">
            <span class="body-sm text-muted-foreground">Total</span>
            <span id="cart-total" class="text-lg font-medium text-primary">
                $0.00
            </span>
        </div>
        <button
            id="cart-checkout"
            data-whatsapp-phone={whatsappPhone}
            class="mb-2 flex w-full cursor-pointer items-center justify-center gap-2 rounded-lg bg-[#25D366] py-2 text-sm font-medium text-white transition hover:opacity-90"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-5 w-5"
                aria-hidden="true"
            >
                <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.652a11.882 11.882 0 005.71 1.454h.006c6.585 0 11.946-5.359 11.949-11.893a11.821 11.821 0 00-3.481-8.46"
                ></path>
            </svg>
            Comprar por WhatsApp
        </button>
        <button
            id="cart-clear"
            class="w-full cursor-pointer rounded-lg border border-border py-2 text-sm font-medium text-foreground hover:bg-muted transition"
        >
            Vaciar carrito
        </button>
    </div>
</aside>

<script>
    import { cart, parsePrice, type CartItem } from '@stores/cart'

    const themeToggle = document.getElementById('theme-toggle')

    themeToggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark')
        localStorage.setItem('theme', isDark ? 'dark' : 'light')
    })

    const menuToggle = document.getElementById('menu-toggle')
    const navMenu = document.getElementById('nav-menu')
    const menuOpenIcon = menuToggle?.querySelector('[data-menu-icon="open"]')
    const menuCloseIcon = menuToggle?.querySelector('[data-menu-icon="close"]')
    const navMenuClose = document.getElementById('nav-menu-close')

    const cartToggle = document.getElementById('cart-toggle')
    const cartPanel = document.getElementById('cart-panel')
    const cartPanelClose = document.getElementById('cart-panel-close')

    const drawerOverlay = document.getElementById('drawer-overlay')

    function updateOverlay() {
        const isAnyOpen =
            !navMenu?.classList.contains('-translate-x-full') ||
            !cartPanel?.classList.contains('translate-x-full')

        drawerOverlay?.classList.toggle('hidden', !isAnyOpen)
        document.body.classList.toggle('overflow-hidden', isAnyOpen)
    }

    function closeMenu() {
        navMenu?.classList.add('-translate-x-full')
        navMenu?.classList.remove('translate-x-0')
        menuOpenIcon?.classList.remove('hidden')
        menuCloseIcon?.classList.add('hidden')
        menuToggle?.setAttribute('aria-expanded', 'false')
        updateOverlay()
    }

    function openMenu() {
        closeCart()
        navMenu?.classList.remove('-translate-x-full')
        navMenu?.classList.add('translate-x-0')
        menuOpenIcon?.classList.add('hidden')
        menuCloseIcon?.classList.remove('hidden')
        menuToggle?.setAttribute('aria-expanded', 'true')
        updateOverlay()
    }

    function closeCart() {
        cartPanel?.classList.add('translate-x-full')
        cartPanel?.classList.remove('translate-x-0')
        cartToggle?.setAttribute('aria-expanded', 'false')
        updateOverlay()
    }

    function openCart() {
        closeMenu()
        cartPanel?.classList.remove('translate-x-full')
        cartPanel?.classList.add('translate-x-0')
        cartToggle?.setAttribute('aria-expanded', 'true')
        updateOverlay()
    }

    menuToggle?.addEventListener('click', () => {
        if (navMenu?.classList.contains('-translate-x-full')) {
            openMenu()
        } else {
            closeMenu()
        }
    })

    cartToggle?.addEventListener('click', () => {
        if (cartPanel?.classList.contains('translate-x-full')) {
            openCart()
        } else {
            closeCart()
        }
    })

    navMenuClose?.addEventListener('click', closeMenu)
    cartPanelClose?.addEventListener('click', closeCart)

    navMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeMenu)
    })

    drawerOverlay?.addEventListener('click', () => {
        closeMenu()
        closeCart()
    })

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            closeMenu()
            closeCart()
        }
    })

    // --- Cart rendering ---
    const cartCount = document.getElementById('cart-count')
    const cartItems = document.getElementById('cart-items')
    const cartEmpty = document.getElementById('cart-empty')
    const cartFooter = document.getElementById('cart-footer')
    const cartTotal = document.getElementById('cart-total')
    const cartClear = document.getElementById('cart-clear')

    function formatCurrency(value: number) {
        return `$${value.toFixed(2)}`
    }

    function itemRow(item: CartItem) {
        const lineTotal = parsePrice(item.price) * item.quantity
        return `
            <div class="flex gap-3">
                <img
                    src="${item.image}"
                    alt="${item.name}"
                    class="h-16 w-16 shrink-0 rounded-lg object-cover bg-muted"
                />
                <div class="flex-1 min-w-0">
                    <p class="card-title text-sm text-foreground truncate">${item.name}</p>
                    <p class="body-sm text-muted-foreground">${formatCurrency(lineTotal)}</p>
                    <div class="mt-2 flex items-center gap-2">
                        <button
                            data-decrease="${item.id}"
                            class="cursor-pointer h-6 w-6 flex items-center justify-center rounded border border-border hover:bg-muted transition"
                            aria-label="Quitar una unidad"
                        >−</button>
                        <span class="text-sm w-4 text-center">${item.quantity}</span>
                        <button
                            data-increase="${item.id}"
                            class="cursor-pointer h-6 w-6 flex items-center justify-center rounded border border-border hover:bg-muted transition"
                            aria-label="Añadir una unidad"
                        >+</button>
                        <button
                            data-remove="${item.id}"
                            class="ml-auto cursor-pointer text-xs text-muted-foreground hover:text-primary transition"
                        >Eliminar</button>
                    </div>
                </div>
            </div>
        `
    }

    function renderCart(items: CartItem[]) {
        const count = cart.getCount()

        if (cartCount) {
            cartCount.textContent = String(count)
            cartCount.classList.toggle('hidden', count === 0)
        }

        const isEmpty = items.length === 0
        cartEmpty?.classList.toggle('hidden', !isEmpty)
        cartItems?.classList.toggle('hidden', isEmpty)
        cartItems?.classList.toggle('flex', !isEmpty)
        cartFooter?.classList.toggle('hidden', isEmpty)

        if (cartItems) cartItems.innerHTML = items.map(itemRow).join('')
        if (cartTotal) cartTotal.textContent = formatCurrency(cart.getTotal())
    }

    cartItems?.addEventListener('click', (event) => {
        const target = (event.target as HTMLElement).closest(
            '[data-remove], [data-increase], [data-decrease]',
        ) as HTMLElement | null
        if (!target) return

        if (target.dataset.remove) {
            cart.remove(Number(target.dataset.remove))
        } else if (target.dataset.increase) {
            const id = Number(target.dataset.increase)
            const item = cart.getItems().find((i) => i.id === id)
            if (item) cart.setQuantity(id, item.quantity + 1)
        } else if (target.dataset.decrease) {
            const id = Number(target.dataset.decrease)
            const item = cart.getItems().find((i) => i.id === id)
            if (item) cart.setQuantity(id, item.quantity - 1)
        }
    })

    cartClear?.addEventListener('click', () => cart.clear())

    // --- Checkout via WhatsApp ---
    const cartCheckout = document.getElementById('cart-checkout')

    cartCheckout?.addEventListener('click', () => {
        const items = cart.getItems()
        if (items.length === 0) return

        const phone = cartCheckout.dataset.whatsappPhone ?? ''
        const lines = items.map((item) => {
            const lineTotal = parsePrice(item.price) * item.quantity
            return `• ${item.name} x${item.quantity} — ${formatCurrency(lineTotal)}`
        })

        const message =
            '¡Hola Entre Rozas! 🌸 Me gustaría comprar:\n\n' +
            lines.join('\n') +
            `\n\nTotal: ${formatCurrency(cart.getTotal())}`

        const url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`
        window.open(url, '_blank', 'noopener')
    })

    window.addEventListener('cart:open', openCart)

    cart.subscribe(renderCart)
</script>
