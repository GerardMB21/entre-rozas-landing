---
import { Sun, Moon } from '@lucide/astro'
---

<header
    class="fixed top-0 w-full z-50 bg-background/95 backdrop-blur border-b border-border"
>
    <div
        class="max-w-7xl mx-auto p-3 sm:p-4 flex items-center justify-between gap-2 sm:gap-4"
    >
        <nav class="flex gap-2 sm:gap-6 text-xs sm:text-base">
            <a href="#shop" class="link-nav"> Comprar </a>
            <a href="#contact" class="link-nav"> Contacto </a>
        </nav>
        <div class="text-center flex-1 min-w-0">
            <h1
                class="text-xl font-light tracking-wide text-primary sm:text-3xl"
            >
                <span class="text-2xl sm:text-4xl">🌸</span> Entre Rozas
            </h1>
            <p class="caption text-xs text-muted-foreground">
                Arreglos Florales de Primera Calidad
            </p>
        </div>
        <button
            id="theme-toggle"
            class="cursor-pointer p-2 rounded-lg hover:bg-muted transition text-foreground shrink-0"
            aria-label="Cambiar tema"
        >
            <Sun size={24} class="btn-theme block dark:hidden" />
            <Moon size={24} class="btn-theme hidden dark:block" />
        </button>
    </div>
</header>

<script>
    const button = document.getElementById('theme-toggle')

    button?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark')
        localStorage.setItem('theme', isDark ? 'dark' : 'light')
    })
</script>
