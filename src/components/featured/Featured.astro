---
import type { Flower } from '@interfaces/carousel'
import Card from './Card.astro'

export interface Props {
    flowers: Flower[]
}

const { flowers } = Astro.props
---

<section id="shop" class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
        <h2 class="section-title mb-12 text-primary">Nuestras Colecciones</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {flowers.map((flower) => <Card flower={flower} />)}
        </div>
    </div>
</section>

<script>
    import { cart } from '@stores/cart'
    import type { Flower } from '@interfaces/carousel'

    document.addEventListener('click', (event) => {
        const target = event.target as HTMLElement
        const button = target.closest('[data-add-to-cart]') as HTMLButtonElement | null
        if (!button) return

        const flower: Flower = {
            id: Number(button.dataset.id),
            name: button.dataset.name ?? '',
            image: button.dataset.image ?? '',
            price: button.dataset.price ?? '',
            description: '',
            width: 0,
            height: 0,
        }

        cart.add(flower)
        window.dispatchEvent(new CustomEvent('cart:open'))
    })
</script>
