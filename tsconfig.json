{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
            "@pages/*": ["./src/pages/*"],
            "@styles/*": ["./src/styles/*"],
            "@layouts/*": ["./src/layouts/*"],
            "@components/*": ["./src/components/*"],
            "@svg/*": ["./src/svg/*"],
            "@assets/*": ["./src/assets/*"],
            "@utils/*": ["./src/utils/*"]
        },
        "jsx": "react-jsx",
        "jsxImportSource": "react"
    }
}
